       "<Figure size 1600x500 with 2 Axes>"
      ]
     },
     "metadata": {},
     "output_type": "display_data"
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "💾 Saved: sector_comparison.png\n"
     ]
    }
   ],
   "source": [
    "def plot_sector_comparison(driver_laps, drivers):\n",
    "    \"\"\"\n",
    "    Heatmap showing sector time performance per driver.\n",
    "    Green = faster than average, Red = slower.\n",
    "    \"\"\"\n",
    "    sector_data = []\n",
    "    for drv in drivers:\n",
    "        d = driver_laps[driver_laps['Driver'] == drv].copy()\n",
    "        # Use median to avoid SC/pit outliers\n",
    "        sector_data.append({\n",
    "            'Driver': drv,\n",
    "            'S1 (med)': d['Sector1Seconds'].median(),\n",
    "            'S2 (med)': d['Sector2Seconds'].median(),\n",
    "            'S3 (med)': d['Sector3Seconds'].median(),\n",
    "            'Avg Lap':  d['LapTimeSeconds'].median()\n",
    "        })\n",
    "    \n",
    "    df = pd.DataFrame(sector_data).set_index('Driver')\n",
    "    \n",
    "    # Normalize per sector (delta from best)\n",
    "    df_delta = df.copy()\n",
    "    for col in ['S1 (med)', 'S2 (med)', 'S3 (med)', 'Avg Lap']:\n",
    "        df_delta[col] = df[col] - df[col].min()\n",
    "    \n",
    "    fig, (ax1, ax2) = plt.subplots(1, 2, figsize=(16, 5), facecolor='#0A000F')\n",
    "    \n",
    "    # Raw times\n",
    "    im1 = ax1.imshow(df[['S1 (med)', 'S2 (med)', 'S3 (med)']].values,\n",
    "                     cmap='RdYlGn_r', aspect='auto')\n",
    "    ax1.set_xticks(range(3)); ax1.set_xticklabels(['Sector 1', 'Sector 2', 'Sector 3'], color='white')\n",
    "    ax1.set_yticks(range(len(drivers))); ax1.set_yticklabels(drivers, color='white')\n",
    "    ax1.set_title('Sector Times (seconds)', color='white', pad=12)\n",
    "    ax1.set_facecolor('#0A000F')\n",
    "    for i in range(len(drivers)):\n",
    "        for j, col in enumerate(['S1 (med)', 'S2 (med)', 'S3 (med)']):\n",
    "            ax1.text(j, i, f'{df[col].iloc[i]:.3f}', ha='center', va='center',\n",
    "                    color='white', fontsize=9, fontweight='bold')\n",
    "    \n",
    "    # Delta from best\n",
    "    im2 = ax2.imshow(df_delta[['S1 (med)', 'S2 (med)', 'S3 (med)']].values,\n",
    "                     cmap='RdYlGn_r', aspect='auto')\n",
    "    ax2.set_xticks(range(3)); ax2.set_xticklabels(['Sector 1', 'Sector 2', 'Sector 3'], color='white')\n",
    "    ax2.set_yticks(range(len(drivers))); ax2.set_yticklabels(drivers, color='white')\n",
    "    ax2.set_title('Delta to Best (seconds) — Green = Faster', color='white', pad=12)\n",
    "    ax2.set_facecolor('#0A000F')\n",
    "    for i in range(len(drivers)):\n",
    "        for j, col in enumerate(['S1 (med)', 'S2 (med)', 'S3 (med)']):\n",
    "            v = df_delta[col].iloc[i]\n",
    "            ax2.text(j, i, f'+{v:.3f}' if v > 0 else '▲BEST',\n",
    "                    ha='center', va='center', color='white', fontsize=9, fontweight='bold')\n",
    "    \n",
    "    for ax in [ax1, ax2]:\n",
    "        ax.set_facecolor('#0A000F')\n",
    "        for spine in ax.spines.values(): spine.set_edgecolor('#333')\n",
    "    \n",
    "    fig.suptitle(f'Sector Performance — {session.event[\"EventName\"]} {SEASON}',\n",
    "                 color='white', fontsize=14, y=1.02)\n",
    "    plt.tight_layout()\n",
    "    plt.savefig('sector_comparison.png', dpi=150, bbox_inches='tight', facecolor='#0A000F')\n",
    "    plt.show()\n",
    "    print('💾 Saved: sector_comparison.png')\n",
    "    return df, df_delta\n",
    "\n",
    "sector_df, sector_delta = plot_sector_comparison(driver_laps, FOCUS_DRIVERS)"
   ]
  },
