    "def plot_tyre_strategy(driver_laps, drivers, total_laps):\n",
    "    \"\"\"\n",
    "    Horizontal bar chart showing compound stints and pit windows.\n",
    "    \"\"\"\n",
    "    COMPOUND_COLORS = {\n",
    "        'SOFT':        '#E8002D',\n",
    "        'MEDIUM':      '#FFD700',\n",
    "        'HARD':        '#CCCCCC',\n",
    "        'INTERMEDIATE':'#43B02A',\n",
    "        'WET':         '#0067FF',\n",
    "    }\n",
    "    \n",
    "    fig, ax = plt.subplots(figsize=(16, len(drivers) * 1.4 + 2), facecolor='#0A000F')\n",
    "    ax.set_facecolor('#0A000F')\n",
    "    \n",
    "    for i, drv in enumerate(drivers):\n",
    "        d = driver_laps[driver_laps['Driver'] == drv].sort_values('LapNumber')\n",
    "        \n",
    "        # Identify stint boundaries\n",
    "        stints = []\n",
    "        current_compound = None\n",
    "        stint_start = None\n",
    "        \n",
    "        for _, row in d.iterrows():\n",
    "            if row['Compound'] != current_compound:\n",
    "                if current_compound is not None:\n",
    "                    stints.append((stint_start, row['LapNumber'] - 1, current_compound))\n",
    "                current_compound = row['Compound']\n",
    "                stint_start = row['LapNumber']\n",
    "        if current_compound:\n",
    "            stints.append((stint_start, d['LapNumber'].max(), current_compound))\n",
    "        \n",
    "        # Draw stints\n",
    "        for (s, e, compound) in stints:\n",
    "            color = COMPOUND_COLORS.get(compound, '#888888')\n",
    "            ax.barh(i, e - s + 1, left=s - 1, height=0.65,\n",
    "                   color=color, alpha=0.9,\n",
    "                   edgecolor='#0A000F', linewidth=1)\n",
    "            # Label if wide enough\n",
    "            if (e - s) >= 4:\n",
    "                ax.text(s - 1 + (e - s + 1) / 2, i,\n",
    "                       compound[:1],  # S / M / H\n",
    "                       ha='center', va='center',\n",
    "                       color='black' if compound != 'SOFT' else 'white',\n",
    "                       fontsize=9, fontweight='bold')\n",
    "        \n",
    "        # Pit stop markers\n",
    "        pit_laps = d[d['PitOutTime'].notna()]['LapNumber'].values\n",
    "        for pl in pit_laps:\n",
    "            ax.axvline(x=pl - 1, ymin=(i) / len(drivers) + 0.05,\n",
    "                      ymax=(i + 1) / len(drivers) - 0.05,\n",
    "                      color='white', linewidth=1.5, alpha=0.7, zorder=5)\n",
    "            ax.text(pl - 0.5, i + 0.45, '▲', color='white',\n",
    "                   fontsize=7, ha='center', alpha=0.8)\n",
    "    \n",
    "    # Axis formatting\n",
    "    ax.set_yticks(range(len(drivers)))\n",
    "    ax.set_yticklabels(drivers, color='white', fontsize=11, fontweight='bold')\n",
    "    ax.set_xlabel('Lap Number', color='white', fontsize=11)\n",
    "    ax.set_xlim(0, total_laps)\n",
    "    ax.set_ylim(-0.5, len(drivers) - 0.5)\n",
    "    ax.tick_params(colors='#888')\n",
    "    ax.set_title(f'Tyre Strategy — {session.event[\"EventName\"]} {SEASON}\\n▲ = Pit Stop',\n",
    "                color='white', fontsize=13, pad=12)\n",
    "    for spine in ax.spines.values(): spine.set_edgecolor('#333')\n",
    "    \n",
    "    # Legend\n",
    "    legend_patches = [mpatches.Patch(color=c, label=k) for k, c in COMPOUND_COLORS.items()\n",
    "                     if k in driver_laps['Compound'].unique()]\n",
    "    ax.legend(handles=legend_patches, loc='lower right', facecolor='#1a0020',\n",
    "             labelcolor='white', fontsize=9, framealpha=0.8)\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig('tyre_strategy.png', dpi=150, bbox_inches='tight', facecolor='#0A000F')\n",
    "    plt.show()\n",
    "    print('💾 Saved: tyre_strategy.png')\n",
    "\n",
    "plot_tyre_strategy(driver_laps, FOCUS_DRIVERS, session.total_laps)"
   ]
  },
