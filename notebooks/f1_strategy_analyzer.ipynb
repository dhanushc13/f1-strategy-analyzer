    "def race_debrief(driver_laps, drivers, session):\n",
    "    \"\"\"\n",
    "    Print a structured post-race strategy analysis.\n",
    "    \"\"\"\n",
    "    print('\\n' + '🏁 '*20)\n",
    "    print(f'  POST-RACE DEBRIEF — {session.event[\"EventName\"].upper()} GRAND PRIX {SEASON}')\n",
    "    print('🏁 '*20)\n",
    "    \n",
    "    for drv in drivers:\n",
    "        d = driver_laps[driver_laps['Driver'] == drv].sort_values('LapNumber')\n",
    "        if d.empty: continue\n",
    "        \n",
    "        start_pos  = d['Position'].iloc[0]\n",
    "        finish_pos = d['Position'].iloc[-1]\n",
    "        best_lap   = d['LapTimeSeconds'].min()\n",
    "        avg_lap    = d['LapTimeSeconds'].median()\n",
    "        pits       = sim.get_actual_pit(drv)\n",
    "        compounds  = d.groupby('Compound')['LapNumber'].count().to_dict()\n",
    "        \n",
    "        pos_change = start_pos - finish_pos\n",
    "        arrow = '▲' if pos_change > 0 else '▼' if pos_change < 0 else '='\n",
    "        \n",
    "        print(f'\\n  [{drv}]  {arrow} P{int(start_pos)} → P{int(finish_pos)}  ({int(pos_change):+d} positions)')\n",
    "        print(f'        Pit stops    : {pits if pits else \"None (1-stop/no stop)\"}')\n",
    "        print(f'        Compounds    : {\", \".join([f\"{k}: {v}L\" for k, v in compounds.items()])}')\n",
    "        print(f'        Best lap     : {best_lap:.3f}s  |  Avg lap: {avg_lap:.3f}s')\n",
    "        \n",
    "        # Key moment: biggest single-lap position gain\n",
    "        if 'Position' in d.columns:\n",
    "            d['PosDelta'] = d['Position'].diff().fillna(0)\n",
    "            best_lap_pos = d.loc[d['PosDelta'].idxmin()]\n",
    "            if best_lap_pos['PosDelta'] < -1:\n",
    "                print(f'        Key moment   : Gained {abs(int(best_lap_pos[\"PosDelta\"]))} positions on Lap {int(best_lap_pos[\"LapNumber\"])}')\n",
    "    \n",
    "    print('\\n' + '─'*52)\n",
    "    print('  STRATEGY VERDICT')\n",
    "    print('─'*52)\n",
    "    \n",
    "    # Simple win/lose for each driver\n",
    "    finishes = [(drv, driver_laps[driver_laps['Driver']==drv]['Position'].iloc[-1])\n",
    "               for drv in drivers if not driver_laps[driver_laps['Driver']==drv].empty]\n",
    "    finishes.sort(key=lambda x: x[1])\n",
    "    \n",
    "    for drv, pos in finishes:\n",
    "        pits = sim.get_actual_pit(drv)\n",
    "        verdict = (\n",
    "            '✅ Strategy worked' if pos <= 3 else\n",
    "            '⚠️  Pit timing cost positions' if pos >= 4 and pits else\n",
    "            '❌ Strategy underperformed.'\n",
    "        )\n",
    "        print(f'  P{pos} {drv:<5} — {verdict}')\n",
    "\n",
    "race_debrief(driver_laps, FOCUS_DRIVERS, session)"
   ]
