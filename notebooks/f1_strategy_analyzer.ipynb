    "def plot_circuit_heatmap(session, driver, lap_number=None, mode='speed'):\n",
    "    \"\"\"\n",
    "    Plots the circuit with a heatmap overlay.\n",
    "    \n",
    "    Parameters:\n",
    "        session    : FastF1 session object\n",
    "        driver     : 3-letter driver code (e.g. 'VER')\n",
    "        lap_number : specific lap to use (None = fastest lap)\n",
    "        mode       : 'speed' | 'throttle' | 'brake' | 'gear' | 'sector'\n",
    "    \"\"\"\n",
    "    # Pick lap\n",
    "    if lap_number:\n",
    "        lap = session.laps.pick_driver(driver).pick_lap(lap_number)\n",
    "    else:\n",
    "        lap = session.laps.pick_driver(driver).pick_fastest()\n",
    "    \n",
    "    # Get telemetry with position\n",
    "    telemetry = lap.get_pos_data().merge(\n",
    "        lap.get_car_data().add_distance(),\n",
    "        left_index=True, right_index=True\n",
    "    )\n",
    "    \n",
    "    x = np.array(telemetry['X'].values)\n",
    "    y = np.array(telemetry['Y'].values)\n",
    "    \n",
    "    # Mode to color map\n",
    "    if mode == 'speed':\n",
    "        color_val = telemetry['Speed'].values\n",
    "        cmap = 'RdYlGn'\n",
    "        label = 'Speed (km/h)'\n",
    "    elif mode == 'throttle':\n",
    "        color_val = telemetry['Throttle'].values\n",
    "        cmap = 'YlOrRd'\n",
    "        label = 'Throttle (%)'\n",
    "    elif mode == 'brake':\n",
    "        color_val = telemetry['Brake'].astype(float).values\n",
    "        cmap = 'RdYlBu_r'\n",
    "        label = 'Braking'\n",
    "    elif mode == 'gear':\n",
    "        color_val = telemetry['nGear'].values\n",
    "        cmap = 'plasma'\n",
    "        label = 'Gear'\n",
    "    else:\n",
    "        color_val = telemetry['Speed'].values  # fallback\n",
    "        cmap = 'RdYlGn'\n",
    "        label = 'Speed (km/h)'\n",
    "    \n",
    "    # Build line segments for color mapping\n",
    "    points = np.array([x, y]).T.reshape(-1, 1, 2)\n",
    "    segments = np.concatenate([points[:-1], points[1:]], axis=1)\n",
    "    \n",
    "    norm = Normalize(vmin=color_val.min(), vmax=color_val.max())\n",
    "    lc = LineCollection(segments, cmap=cmap, norm=norm, linewidth=4, zorder=2)\n",
    "    lc.set_array(color_val[:-1])\n",
    "    \n",
    "    # Plot\n",
    "    fig, ax = plt.subplots(figsize=(14, 10), facecolor='#0A000F')\n",
    "    ax.set_facecolor('#0A000F')\n",
    "    \n",
    "    # Track shadow\n",
    "    ax.plot(x, y, color='#1a0020', linewidth=16, zorder=1, solid_capstyle='round')\n",
    "    ax.plot(x, y, color='#2a0030', linewidth=12, zorder=1, solid_capstyle='round')\n",
    "    \n",
    "    # Colored track\n",
    "    ax.add_collection(lc)\n",
    "    \n",
    "    # Start/finish line\n",
    "    ax.scatter(x[0], y[0], color='white', s=200, zorder=10, marker='|', linewidths=3)\n",
    "    ax.annotate('START/FINISH', (x[0], y[0]), fontsize=7, color='white',\n",
    "                xytext=(10, 10), textcoords='offset points',\n",
    "                fontfamily='monospace')\n",
    "    \n",
    "    # Colorbar\n",
    "    cbar = plt.colorbar(lc, ax=ax, fraction=0.02, pad=0.02)\n",
    "    cbar.set_label(label, color='white', fontsize=10)\n",
    "    cbar.ax.yaxis.set_tick_params(color='white')\n",
    "    plt.setp(cbar.ax.yaxis.get_ticklabels(), color='white')\n",
    "    \n",
    "    lap_time = lap['LapTime']\n",
    "    title = f'{session.event[\"EventName\"]} {session.event.year}\\n'\n",
    "    title += f'{driver} — {\"Fastest\" if not lap_number else f\"Lap {lap_number}\"} · {label} Heatmap'\n",
    "    if pd.notna(lap_time):\n",
    "        title += f' · Lap Time: {lap_time}'\n",
    "    \n",
    "    ax.set_title(title, color='white', fontsize=13, pad=15)\n",
    "    ax.tick_params(colors='#333')\n",
    "    for spine in ax.spines.values():\n",
    "        spine.set_visible(False)\n",
    "    ax.set_xticks([]); ax.set_yticks([])\n",
    "    ax.set_aspect('equal')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig(f'circuit_{driver}_{mode}.png', dpi=150, bbox_inches='tight',\n",
    "                facecolor='#0A000F')\n",
    "    plt.show()\n",
    "    print(f'💾 Saved: circuit_{driver}_{mode}.png')\n",
    "\n",
    "# ── GENERATE PLOTS ──\n",
    "print('🗺️ Generating circuit heatmaps...')\n",
    "plot_circuit_heatmap(session, driver='VER', mode='speed')"
   ]
