    "def plot_whatif_sweep(sim, driver, pit_range=None):\n",
    "    \"\"\"\n",
    "    Sweep all possible pit laps and visualize the time delta.\n",
    "    Shows the optimal pit window clearly.\n",
    "    \"\"\"\n",
    "    actual_pit = sim.get_actual_pit(driver)[0]\n",
    "    total_laps = sim.laps[sim.laps['Driver'] == driver]['LapNumber'].max()\n",
    "    \n",
    "    if pit_range is None:\n",
    "        pit_range = range(max(3, int(actual_pit) - 20), min(int(total_laps) - 5, int(actual_pit) + 20))\n",
    "    \n",
    "    results = []\n",
    "    for pl in pit_range:\n",
    "        r = sim.simulate(driver, pl)\n",
    "        if 'error' not in r:\n",
    "            results.append({\n",
    "                'pit_lap':    pl,\n",
    "                'time_delta': r['time_delta_s'],\n",
    "                'finish':     r['simulated_finish'],\n",
    "                'verdict':    r['verdict']\n",
    "            })\n",
    "    \n",
    "    df_sweep = pd.DataFrame(results)\n",
    "    \n",
    "    fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(14, 8), facecolor='#0A000F',\n",
    "                                   gridspec_kw={'height_ratios': [3, 1]})\n",
    "    \n",
    "    # Colors per bar\n",
    "    colors = ['#22DD88' if v < -1 else '#E8002D' if v > 1 else '#FFD700'\n",
    "             for v in df_sweep['time_delta']]\n",
    "    \n",
    "    ax1.bar(df_sweep['pit_lap'], -df_sweep['time_delta'], color=colors, alpha=0.85, width=0.8)\n",
    "    ax1.axhline(0, color='#666', linewidth=1, linestyle='--')\n",
    "    ax1.axvline(actual_pit, color='white', linewidth=2, linestyle='-', alpha=0.7,\n",
    "               label=f'Actual Pit (Lap {actual_pit})')\n",
    "    ax1.axvline(WHATIF_PIT_LAP, color='#FFD700', linewidth=2, linestyle='--', alpha=0.9,\n",
    "               label=f'Simulated Pit (Lap {WHATIF_PIT_LAP})')\n",
    "    \n",
    "    ax1.set_facecolor('#0A000F')\n",
    "    ax1.set_ylabel('Time Gain vs Actual (s)\\n▲ Better  ▼ Worse', color='white', fontsize=10)\n",
    "    ax1.set_title(f'Optimal Pit Window — {driver} · {session.event[\"EventName\"]} {SEASON}\\n'\n",
    "                 f'Green = Better than actual | Red = Worse', color='white', fontsize=12, pad=10)\n",
    "    ax1.tick_params(colors='#888'); ax1.set_xlabel('')\n",
    "    for sp in ax1.spines.values(): sp.set_edgecolor('#333')\n",
    "    ax1.legend(facecolor='#1a0020', labelcolor='white', fontsize=9)\n",
    "    \n",
    "    # Finish position row\n",
    "    ax2.plot(df_sweep['pit_lap'], df_sweep['finish'], color='#7B61FF',\n",
    "            linewidth=2, marker='o', markersize=4)\n",
    "    ax2.axvline(actual_pit, color='white', linewidth=1.5, alpha=0.6)\n",
    "    ax2.axvline(WHATIF_PIT_LAP, color='#FFD700', linewidth=1.5, linestyle='--', alpha=0.8)\n",
    "    ax2.set_facecolor('#0A000F')\n",
    "    ax2.set_ylabel('Finish\\nPos.', color='white', fontsize=9)\n",
    "    ax2.set_xlabel('Pit Lap', color='white', fontsize=10)\n",
    "    ax2.invert_yaxis()\n",
    "    ax2.tick_params(colors='#888')\n",
    "    for sp in ax2.spines.values(): sp.set_edgecolor('#333')\n",
    "    \n",
    "    # Find optimal\n",
    "    best = df_sweep.loc[df_sweep['time_delta'].idxmin()]\n",
    "    print(f'\\n🏆 OPTIMAL PIT LAP: Lap {int(best[\"pit_lap\"])} → {best[\"time_delta\"]:+.2f}s vs actual strategy')\n",
    "    \n",
    "    plt.tight_layout()\n",
    "    plt.savefig(f'whatif_sweep_{driver}.png', dpi=150, bbox_inches='tight', facecolor='#0A000F')\n",
    "    plt.show()\n",
    "    print(f'💾 Saved: whatif_sweep_{driver}.png')\n",
    "    return df_sweep\n",
    "\n",
    "sweep_df = plot_whatif_sweep(sim, driver=WHATIF_DRIVER)"
   ]
