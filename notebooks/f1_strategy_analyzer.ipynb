    "---\n",
    "## 🔮 Section 6 — What-If Pit Strategy Simulator\n",
    "**Core feature:** Simulate what would have happened if a driver pitted on a different lap.\n",
    "\n",
    "Model logic:\n",
    "- Calculates tyre degradation curve from real lap time progression\n",
    "- Models undercut window (pit early → fresh tyre pace advantage)\n",
    "- Models overcut window (pit late → track position advantage)\n",
    "- Returns estimated position delta and cumulative time delta"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "ff72f0c1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "✅ StrategySimulator initialized\n"
     ]
    }
   ],
   "source": [
    "class StrategySimulator:\n",
    "    \"\"\"\n",
    "    What-If pit stop strategy simulator.\n",
    "    Uses tyre degradation curves from real lap time data.\n",
    "    \"\"\"\n",
    "    \n",
    "    TYRE_PACE_ADV = {\n",
    "        # (new_compound, old_compound): seconds per lap advantage on fresh tyre\n",
    "        ('SOFT',   'MEDIUM'): 0.8,\n",
    "        ('SOFT',   'HARD'):   1.2,\n",
    "        ('MEDIUM', 'HARD'):   0.5,\n",
    "        ('MEDIUM', 'SOFT'):  -0.3,\n",
    "        ('HARD',   'SOFT'):  -0.6,\n",
    "        ('HARD',   'MEDIUM'):-0.3,\n",
    "    }\n",
    "    PIT_TIME_LOSS = 22.0  # seconds stationary + pit lane delta\n",
    "    TYRE_DEG_RATE = 0.08  # seconds per lap degradation\n",
    "    \n",
    "    def __init__(self, driver_laps, session):\n",
    "        self.laps = driver_laps\n",
    "        self.session = session\n",
    "    \n",
    "    def get_actual_pit(self, driver):\n",
    "        \"\"\"Returns actual pit lap(s) for a driver.\"\"\"\n",
    "        d = self.laps[self.laps['Driver'] == driver]\n",
    "        return sorted(d[d['PitOutTime'].notna()]['LapNumber'].tolist())\n",
    "    \n",
    "    def get_tyre_deg_curve(self, driver, compound):\n",
    "        \"\"\"Fit degradation rate from real lap times on a compound.\"\"\"\n",
    "        d = self.laps[\n",
    "            (self.laps['Driver'] == driver) &\n",
    "            (self.laps['Compound'] == compound) &\n",
    "            (self.laps['LapTimeSeconds'] > 0) &\n",
    "            (self.laps['IsPersonalBest'] == False)  # exclude hotlaps\n",
    "        ].copy()\n",
    "        \n",
    "        if len(d) < 3:\n",
    "            return self.TYRE_DEG_RATE  # fallback\n",
    "        \n",
    "        # Fit linear degradation to lap times on this compound\n",
    "        # stint_lap = laps since this compound was new\n",
    "        d = d.sort_values('LapNumber')\n",
    "        d['stint_lap'] = range(len(d))\n",
    "        d_clean = d[d['LapTimeSeconds'] < d['LapTimeSeconds'].median() * 1.03]\n",
    "        \n",
    "        if len(d_clean) < 2:\n",
    "            return self.TYRE_DEG_RATE\n",
    "        \n",
    "        coef = np.polyfit(d_clean['stint_lap'], d_clean['LapTimeSeconds'], 1)\n",
    "        return max(0.02, coef[0])  # slope = seconds per lap degradation\n",
    "    \n",
    "    def simulate(self, driver, whatif_pit_lap, whatif_compound=None):\n",
    "        \"\"\"\n",
    "        Simulate alternate pit strategy.\n",
    "        \n",
    "        Parameters:\n",
    "            driver          : 3-letter code e.g. 'HAM'\n",
    "            whatif_pit_lap  : alternate pit lap to test\n",
    "            whatif_compound : compound after pit (None = auto-select same as actual)\n",
    "        \n",
    "        Returns:\n",
    "            dict with simulation results\n",
    "        \"\"\"\n",
    "        d = self.laps[self.laps['Driver'] == driver].sort_values('LapNumber')\n",
    "        actual_pits = self.get_actual_pit(driver)\n",
    "        total_laps = d['LapNumber'].max()\n",
    "        \n",
    "        if not actual_pits:\n",
    "            return {'error': f'{driver} made no pit stops — cannot simulate'}\n",
    "        \n",
    "        actual_pit_lap = actual_pits[0]\n",
    "        \n",
    "        # Get actual compound after pit\n",
    "        post_pit = d[d['LapNumber'] > actual_pit_lap].head(1)\n",
    "        actual_new_compound = post_pit['Compound'].values[0] if len(post_pit) else 'HARD'\n",
    "        new_compound = whatif_compound or actual_new_compound\n",
    "        \n",
    "        pre_pit = d[d['LapNumber'] < actual_pit_lap].head(1)\n",
    "        old_compound = pre_pit['Compound'].values[0] if len(pre_pit) else 'MEDIUM'\n",
    "        \n",
    "        # Lap time difference around the pit window\n",
    "        lap_delta = whatif_pit_lap - actual_pit_lap\n",
    "        \n",
    "        # Degradation rates\n",
    "        deg_old = self.get_tyre_deg_curve(driver, old_compound)\n",
    "        deg_new = self.get_tyre_deg_curve(driver, new_compound)\n",
    "        \n",
    "        # Pace advantage from fresher tyres at whatif lap\n",
    "        tyre_key = (new_compound, old_compound)\n",
    "        base_pace_adv = self.TYRE_PACE_ADV.get(tyre_key, 0.3)\n",
    "        \n",
    "        # Extra degradation if pitting later (tyres are more worn)\n",
    "        extra_wear_delta = lap_delta * deg_old\n",
    "        \n",
    "        # Laps benefiting from fresh tyre\n",
    "        remaining_laps = total_laps - whatif_pit_lap\n",
    "        actual_remaining = total_laps - actual_pit_lap\n",
    "        \n",
    "        # Cumulative time delta vs actual strategy\n",
    "        # Positive = slower than actual, Negative = faster than actual\n",
    "        if lap_delta < 0:\n",
    "            # Earlier pit: lost track position but more laps on fresh tyre\n",
    "            time_gained_fresh  = abs(lap_delta) * base_pace_adv  # more laps fresh\n",
    "            time_lost_position = abs(lap_delta) * 0.4            # lost track pos\n",
    "            total_delta = time_lost_position - time_gained_fresh\n",
    "        else:\n",
    "            # Later pit: kept track position but tyres degraded more\n",
    "            time_lost_deg  = extra_wear_delta * lap_delta\n",
    "            time_gained_pos = lap_delta * 0.35\n",
    "            total_delta = time_lost_deg - time_gained_pos\n",
    "        \n",
    "        # Clamp to realistic range\n",
    "        total_delta = max(-30, min(30, total_delta))\n",
    "        \n",
    "        # Estimate position impact (approx 2.5s per position at Monaco)\n",
    "        pos_delta = round(total_delta / 2.5)\n",
    "        actual_finish = d['Position'].iloc[-1]\n",
    "        sim_finish = max(1, min(20, int(actual_finish) + pos_delta))\n",
    "        \n",
    "        return {\n",
    "            'driver':           driver,\n",
    "            'actual_pit_lap':   actual_pit_lap,\n",
    "            'simulated_pit_lap': whatif_pit_lap,\n",
    "            'lap_delta':        lap_delta,\n",
    "            'old_compound':     old_compound,\n",
    "            'new_compound':     new_compound,\n",
    "            'deg_rate_old':     round(deg_old, 4),\n",
    "            'deg_rate_new':     round(deg_new, 4),\n",
    "            'time_delta_s':     round(total_delta, 2),\n",
    "            'actual_finish':    int(actual_finish),\n",
    "            'simulated_finish': sim_finish,\n",
    "            'position_delta':   -pos_delta,  # negative = improvement\n",
    "            'verdict':          'BETTER' if total_delta < -1 else 'WORSE' if total_delta > 1 else 'NEUTRAL'\n",
    "        }\n",
    "\n",
    "sim = StrategySimulator(driver_laps, session)\n",
    "print('✅ StrategySimulator initialized')"
   ]
  },
