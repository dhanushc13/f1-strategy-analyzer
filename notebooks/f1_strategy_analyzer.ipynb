    "def plot_position_trace(driver_laps, drivers):\n",
    "    \"\"\"\n",
    "    Interactive Plotly chart — position changes across all laps.\n",
    "    Hover to see driver/lap/position info.\n",
    "    \"\"\"\n",
    "    DRIVER_COLORS = {\n",
    "        'VER': '#3671C6', 'PER': '#3671C6',\n",
    "        'LEC': '#E8002D', 'SAI': '#FF8800',\n",
    "        'HAM': '#27F4D2', 'RUS': '#27F4D2',\n",
    "        'ALO': '#358C75', 'STR': '#358C75',\n",
    "        'NOR': '#FF8000', 'PIA': '#FF8000',\n",
    "        'GAS': '#2B4562', 'OCO': '#2B4562',\n",
    "    }\n",
    "    DEFAULT_COLOR = '#AAAAAA'\n",
    "    \n",
    "    fig = go.Figure()\n",
    "    \n",
    "    for drv in drivers:\n",
    "        d = driver_laps[driver_laps['Driver'] == drv].sort_values('LapNumber')\n",
    "        color = DRIVER_COLORS.get(drv, DEFAULT_COLOR)\n",
    "        \n",
    "        # Main line\n",
    "        fig.add_trace(go.Scatter(\n",
    "            x=d['LapNumber'], y=d['Position'],\n",
    "            mode='lines',\n",
    "            name=drv,\n",
    "            line=dict(color=color, width=2.5),\n",
    "            hovertemplate=f'<b>{drv}</b><br>Lap: %{{x}}<br>Position: P%{{y}}<br>Compound: %{{customdata[0]}}<br>Lap Time: %{{customdata[1]:.3f}}s<extra></extra>',\n",
    "            customdata=np.column_stack([d['Compound'].values,\n",
    "                                        d['LapTimeSeconds'].fillna(0).values])\n",
    "        ))\n",
    "        \n",
    "        # Pit stop markers\n",
    "        pit_laps = d[d['PitOutTime'].notna()]\n",
    "        fig.add_trace(go.Scatter(\n",
    "            x=pit_laps['LapNumber'], y=pit_laps['Position'],\n",
    "            mode='markers',\n",
    "            name=f'{drv} Pit',\n",
    "            marker=dict(symbol='triangle-up', size=10, color=color,\n",
    "                       line=dict(width=1, color='white')),\n",
    "            showlegend=False,\n",
    "            hovertemplate=f'<b>{drv} PIT STOP</b><br>Lap: %{{x}}<br>Position: P%{{y}}<extra></extra>'\n",
    "        ))\n",
    "    \n",
    "    fig.update_layout(\n",
    "        title=dict(\n",
    "            text=f'Position Changes — {session.event[\"EventName\"]} {SEASON}<br><sup>▲ markers = Pit Stops</sup>',\n",
    "            font=dict(size=16, color='white')\n",
    "        ),\n",
    "        paper_bgcolor='#0A000F',\n",
    "        plot_bgcolor='#110015',\n",
    "        font=dict(color='white'),\n",
    "        xaxis=dict(\n",
    "            title='Lap Number', gridcolor='#222', tickcolor='#666',\n",
    "            title_font=dict(color='white')\n",
    "        ),\n",
    "        yaxis=dict(\n",
    "            title='Position', autorange='reversed',\n",
    "            tickvals=list(range(1, 21)),\n",
    "            ticktext=[f'P{i}' for i in range(1, 21)],\n",
    "            gridcolor='#222', tickcolor='#666',\n",
    "            title_font=dict(color='white')\n",
    "        ),\n",
    "        legend=dict(\n",
    "            bgcolor='rgba(20,0,30,0.85)', bordercolor='#333',\n",
    "            font=dict(color='white')\n",
    "        ),\n",
    "        hovermode='x unified',\n",
    "        height=520\n",
    "    )\n",
    "    \n",
    "    fig.write_html('position_trace.html')\n",
    "    fig.show()\n",
    "    print('💾 Saved interactive chart: position_trace.html')\n",
    "\n",
    "plot_position_trace(driver_laps, FOCUS_DRIVERS)"
   ]
