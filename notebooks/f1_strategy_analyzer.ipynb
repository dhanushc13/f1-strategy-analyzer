   "source": [
    "# Filter laps for focus drivers only\n",
    "driver_laps = laps[laps['Driver'].isin(FOCUS_DRIVERS)].copy()\n",
    "\n",
    "# Convert lap times to seconds for easier math\n",
    "driver_laps['LapTimeSeconds'] = driver_laps['LapTime'].dt.total_seconds()\n",
    "driver_laps['Sector1Seconds'] = driver_laps['Sector1Time'].dt.total_seconds()\n",
    "driver_laps['Sector2Seconds'] = driver_laps['Sector2Time'].dt.total_seconds()\n",
    "driver_laps['Sector3Seconds'] = driver_laps['Sector3Time'].dt.total_seconds()\n",
    "\n",
    "# Quick summary per driver\n",
    "summary = driver_laps.groupby('Driver').agg(\n",
    "    TotalLaps    = ('LapNumber', 'max'),\n",
    "    AvgLapTime   = ('LapTimeSeconds', 'mean'),\n",
    "    FastestLap   = ('LapTimeSeconds', 'min'),\n",
    "    Compounds    = ('Compound', lambda x: list(x.unique())),\n",
    "    PitCount     = ('PitOutTime', lambda x: x.notna().sum())\n",
    ").round(3)\n",
    "\n",
    "print('\\n📈 Driver Summary:')\n",
    "display(summary)"
   ]
